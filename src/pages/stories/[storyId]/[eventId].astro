---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getSiteData } from "../../../lib/site-data";
import { renderMarkdown } from "../../../lib/vault";
const data = getSiteData();
export function getStaticPaths() { return getSiteData().stories.flatMap((story) => story.sequences.flatMap((sequence) => sequence.events.map((event) => ({ params: { storyId: story.route.split("/")[2], eventId: event.route.split("/")[3] }, props: { story, event } })))); }
const { story, event } = Astro.props;
const refs = event.canonRefs.map((id) => data.entities.find((entity) => entity.id === id)).filter(Boolean);
const html = event.text ? renderMarkdown(event.text, (target) => { const found = data.entities.find((entity) => entity.id === target || entity.name === target); return found ? { route: found.route, label: found.name } : undefined; }) : "";
---
<BaseLayout title={`${event.name} · ${data.title}`}><article class="entry"><div class="entry-heading"><p class="chapter">{story.name}</p><h1>{event.name}</h1>{event.description && <p>{event.description}</p>}</div>{html && <div class="entry-body" set:html={html} />}</article><aside class="related"><h2>Canon references</h2><ul>{refs.map((entity) => <li><a href={entity.route}>{entity.name}</a><span>{entity.type}</span></li>)}</ul></aside></BaseLayout>
