---
import "../styles/global.css";
import { getSiteData } from "../lib/site-data";

const data = getSiteData();
const { title = data.title, description = data.description } = Astro.props;
const orderedTypes = [...new Set(data.entities.map((entity) => entity.type))].sort((a, b) => {
  const order = data.config.navigation?.typeOrder ?? [];
  return (order.indexOf(a) + 1 || 999) - (order.indexOf(b) + 1 || 999) || a.localeCompare(b);
});
const searchEntries = [
  ...data.entities.map((entity) => ({ name: entity.name, type: entity.type, route: entity.route })),
  ...data.stories.flatMap((story) => story.sequences.flatMap((sequence) => sequence.events.map((event) => ({ name: event.name, type: story.name, route: event.route })))),
];
---

<!doctype html>
<html lang={data.config.site?.locale ?? "en"}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body style={`--accent:${data.config.theme?.accentColor ?? "#C89B3C"}`}>
    <header class="topbar">
      <a class="brand" href="/">{data.title}</a>
      <nav aria-label="Primary navigation"><a href="/">Universe</a><a href="/stories/">Stories</a></nav>
      <div class="search"><label for="compendium-search" class="visually-hidden">Search the Compendium</label><input id="compendium-search" type="search" placeholder="Search the Compendium…" autocomplete="off" /><ul id="search-results" hidden></ul></div>
    </header>
    <div class="shell">
      <aside class="toc" aria-label="Table of contents">
        <p class="toc-title">Table of Contents</p>
        {orderedTypes.map((type) => <section><h2>{type}</h2><ul>{data.entities.filter((entity) => entity.type === type).map((entity) => <li><a href={entity.route}>{entity.name}</a></li>)}</ul></section>)}
      </aside>
      <main><slot /></main>
    </div>
    <footer>Built from a portable Everend vault.</footer>
    <script define:vars={{ searchEntries }}>
      const input = document.querySelector("#compendium-search");
      const results = document.querySelector("#search-results");
      input?.addEventListener("input", () => {
        const query = input.value.trim().toLowerCase();
        const matches = query ? searchEntries.filter((entry) => `${entry.name} ${entry.type}`.toLowerCase().includes(query)).slice(0, 8) : [];
        results.replaceChildren(...matches.map((entry) => { const item = document.createElement("li"); const link = document.createElement("a"); link.href = entry.route; link.textContent = `${entry.name} · ${entry.type}`; item.append(link); return item; }));
        results.hidden = matches.length === 0;
      });
    </script>
  </body>
</html>
