{
  "name": "@everendforge/compendium",
  "version": "0.2.2",
  "private": false,
  "type": "module",
  "description": "Static, publishable universe compendium and desktop reader for Everend Forge.",
  "license": "MIT OR Apache-2.0",
  "bin": {
    "everend-compendium": "./bin/everend-compendium.mjs"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "site:build": "tsx cli/cli.ts build",
    "site:dev": "tsx cli/cli.ts dev",
    "init": "tsx cli/cli.ts init",
    "export:markdown": "tsx cli/cli.ts markdown",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "lint": "eslint src tests cli",
    "format:check": "prettier --check .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "astro": "^5.15.0",
    "d3-force": "^3.0.0",
    "dompurify": "^3.2.4",
    "lucide-react": "^1.8.0",
    "marked": "^15.0.12",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sanitize-html": "^2.17.0",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/d3-force": "^3.0.10",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/sanitize-html": "^2.16.0",
    "@typescript-eslint/eslint-plugin": "^8.37.0",
    "@typescript-eslint/parser": "^8.37.0",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^9.34.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.6.2",
    "tsx": "^4.20.5",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.37.0",
    "vite": "^6.4.3",
    "vitest": "^3.2.4"
  }
}
