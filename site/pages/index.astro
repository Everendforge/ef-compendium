---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getSiteData } from "../../src/lib/node/site-data";
const data = getSiteData();
const featured = data.entities[0];
const cover = data.config.site?.coverImage ? `linear-gradient(90deg, rgba(3,18,29,.9), rgba(3,18,29,.2)), url('/assets/${data.config.site.coverImage}')` : undefined;
---
<BaseLayout title={data.title}>
  <section class="cover" style={cover ? `background-image: ${cover}` : undefined}>
    <div><p class="chapter">The living archive</p><h1>{data.title}</h1><p>{data.description}</p>{featured && <a class="action" href={featured.route}>Begin reading</a>}</div>
  </section>
  <section class="intro"><p class="kicker">A world in reference</p><h2>Every person, place, and story in one readable edition.</h2><p>This Compendium is generated from portable Markdown canon and editorial story scenes. Follow links, explore related entries, or search the archive.</p></section>
  <section class="directory"><h2>Browse the archive</h2><div class="type-list">{Array.from(new Set(data.entities.map((entity) => entity.type))).sort().map((type) => <a href={`#${type}`}><span>{type}</span><strong>{data.entities.filter((entity) => entity.type === type).length}</strong></a>)}</div></section>
</BaseLayout>
